@page
@model IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "The 80s Never Died";
}

<section class="hero">
  <div class="stars" id="stars"></div>
  <div class="hero-title-glow"></div>
  <div class="chrome-ring"></div>
  <div class="skyline">
    <svg viewBox="0 0 1440 200" preserveAspectRatio="none">
      <polygon points="0,200 0,160 40,160 40,100 60,100 60,130 100,130 100,70 120,70 120,130 160,130 160,90 200,90 200,140 240,140 240,110 260,110 260,60 280,60 280,110 320,110 320,150 380,150 380,80 400,80 400,120 440,120 440,140 500,140 500,55 520,55 520,140 560,140 560,100 600,100 600,130 640,130 640,75 680,75 680,45 700,45 700,75 720,75 720,130 760,130 760,110 800,110 800,85 840,85 840,50 860,50 860,85 880,85 880,120 920,120 920,140 960,140 960,65 980,65 980,130 1020,130 1020,90 1060,90 1060,140 1100,140 1100,110 1140,110 1140,70 1160,70 1160,110 1200,110 1200,150 1240,150 1240,95 1260,95 1260,140 1300,140 1300,120 1340,120 1340,80 1360,80 1360,140 1400,140 1400,160 1440,160 1440,200" />
    </svg>
  </div>
  <div class="hero-horizon"></div>
  <div class="grid-floor"></div>

  <span class="hero-badge">&#x25B8; Rewind &bull; Relive &bull; Replay</span>
  <h1>
    <span class="line1">alive85</span>
    <span class="line2">The 80s Never Died</span>
  </h1>
  <p class="hero-sub">Shop &bull; Play &bull; Discover &bull; Remember</p>
  <div class="hero-buttons">
    <a class="btn-primary" asp-page="/Shop/Index">Shop the Era</a>
    <a class="btn-secondary" href="#trivia">Play Trivia</a>
  </div>
</section>

<div class="ticker-bar" role="marquee" aria-label="Latest updates">
  <div class="ticker-inner">
    <span>&#x2605; New Drop: <span class="highlight">Chrome Edition</span> Collection &#x2605;</span>
    <span>&#x1f579;&#xFE0F; Weekly Trivia: Win a Free 85 Crate &#x2605;</span>
    <span>&#x1f4fc; Top Pick: <span class="highlight">1985 Time Capsule Box</span> &#x2605;</span>
    <span>&#x1f3b8; Now Playing: Synthwave Essentials Playlist &#x2605;</span>
    <span>&#x2605; New Drop: <span class="highlight">Chrome Edition</span> Collection &#x2605;</span>
    <span>&#x1f579;&#xFE0F; Weekly Trivia: Win a Free 85 Crate &#x2605;</span>
    <span>&#x1f4fc; Top Pick: <span class="highlight">1985 Time Capsule Box</span> &#x2605;</span>
    <span>&#x1f3b8; Now Playing: Synthwave Essentials Playlist &#x2605;</span>
  </div>
</div>

<section class="shop-section" id="shop">
  <span class="section-vlabel">Fresh Drops 2025</span>
  <div class="shop-header">
    <div class="section-label">// Shop</div>
    <h2 class="section-title">Fresh Drops</h2>
    <p class="section-desc">Original designs inspired by the golden decade. Limited runs, maximum nostalgia.</p>
  </div>
  <div class="product-grid">
    @foreach (var product in Model.FeaturedProducts)
    {
      <a class="product-card" asp-page="/Shop/Product" asp-route-id="@product.Id">
        <div class="product-img">
          @if (!string.IsNullOrEmpty(product.Tag))
          {
            <span class="product-tag">@product.Tag</span>
          }
          @if (!string.IsNullOrEmpty(product.ImagePath))
          {
            <img src="@product.ImagePath" alt="@product.Name" class="product-svg" />
          }
          else
          {
            <span class="emoji-display">@product.Emoji</span>
          }
        </div>
        <div class="product-info">
          <div class="product-name">@product.Name</div>
          <div class="product-desc">@product.Description</div>
          <div class="product-price">
            @product.Price.ToString("C")@if (!string.IsNullOrEmpty(product.PriceSuffix))
            {<span class="price-suffix">@product.PriceSuffix</span>}
          </div>
        </div>
      </a>
    }
  </div>
</section>

<section class="trivia-section" id="trivia">
  <span class="section-vlabel">Test Your Knowledge</span>
  <div class="section-label">// Daily Trivia</div>
  <h2 class="section-title">Test Your 80s IQ</h2>
  <p class="section-desc" style="margin: 0 auto;">5 questions per session. How many can you nail?</p>
  <div class="trivia-card" id="trivia-card" role="region" aria-label="Trivia game">
    <div class="trivia-question" id="trivia-question" aria-live="polite">Loading...</div>
    <div class="trivia-options" id="trivia-options" role="group" aria-label="Answer options"></div>
    <div class="trivia-explanation" id="trivia-explanation" aria-live="polite"></div>
    <div class="trivia-footer" id="trivia-footer" aria-live="polite"></div>
  </div>
</section>

<section class="categories-section" id="explore" aria-label="Explore categories">
  <span class="section-vlabel">Explore the Decade</span>
  <div style="text-align:center">
    <div class="section-label">// Explore</div>
    <h2 class="section-title">Dive Into the Decade</h2>
    <p class="section-desc" style="margin: 0 auto;">Everything that made the 80s iconic — curated, catalogued, and alive.</p>
  </div>
  <div class="cat-grid">
    <a class="cat-card" asp-page="/Explore/Category" asp-route-slug="movies"><span class="cat-icon">&#x1f3ac;</span><div class="cat-name">Movies</div><div class="cat-count">240+ titles ranked &amp; reviewed</div></a>
    <a class="cat-card" asp-page="/Explore/Category" asp-route-slug="music"><span class="cat-icon">&#x1f3b5;</span><div class="cat-name">Music</div><div class="cat-count">Playlists, deep cuts &amp; vinyl guides</div></a>
    <a class="cat-card" asp-page="/Explore/Category" asp-route-slug="fashion"><span class="cat-icon">&#x1f457;</span><div class="cat-name">Fashion</div><div class="cat-count">Style guides &amp; trend breakdowns</div></a>
    <a class="cat-card" asp-page="/Explore/Category" asp-route-slug="gaming"><span class="cat-badge">HOT</span><span class="cat-icon">&#x1f579;&#xFE0F;</span><div class="cat-name">Gaming</div><div class="cat-count">Arcade classics &amp; console history</div></a>
    <a class="cat-card" asp-page="/Explore/Category" asp-route-slug="tv-culture"><span class="cat-icon">&#x1f4fa;</span><div class="cat-name">TV &amp; Culture</div><div class="cat-count">The shows, ads &amp; moments we lived</div></a>
  </div>
</section>

<section class="cta-section">
  <div class="section-label">// Stay Connected</div>
  <h2 class="section-title">The 85 Rewind</h2>
  <p class="section-desc">A weekly dose of 80s nostalgia — trivia, new drops, playlists, and deep dives. Free forever.</p>
  @if (Model.NewsletterSubmitted)
  {
    <div class="newsletter-success">
      <span class="newsletter-success-icon">&#x2713;</span>
      <span>You're in! Welcome to The 85 Rewind.</span>
    </div>
  }
  else
  {
    <form method="post" class="email-form" aria-label="Newsletter signup">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input type="email" id="newsletter-email" name="NewsletterEmail" placeholder="your@@email.com" required autocomplete="email">
      <button type="submit">Subscribe</button>
    </form>
  }
</section>

@section Scripts {
<script>
var triviaData = @Html.Raw(JsonSerializer.Serialize(Model.TriviaQuestions, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
</script>
<script src="/js/trivia.js"></script>
}
