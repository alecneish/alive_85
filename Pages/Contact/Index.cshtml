@page
@model alive_85.Pages.Contact.IndexModel
@{
    ViewData["Title"] = "Contact";
}

<section class="contact-section">
  <div class="contact-container">
    <div class="contact-info-col">
      <div class="section-label">// Contact</div>
      <h1 class="section-title">Get in Touch</h1>
      <p class="section-desc">Got a question, idea, or just want to talk 80s? Drop us a line. We read everything.</p>
      <div class="contact-details">
        <div class="contact-detail-item">
          <span class="contact-detail-label">Email</span>
          <span class="contact-detail-value">hello&#64;alive85.com</span>
        </div>
        <div class="contact-detail-item">
          <span class="contact-detail-label">Response Time</span>
          <span class="contact-detail-value">Within 24 hours</span>
        </div>
        <div class="contact-detail-item">
          <span class="contact-detail-label">Location</span>
          <span class="contact-detail-value">The Internet, circa 1985</span>
        </div>
      </div>
    </div>
    <div class="contact-form-col">
      @if (Model.Submitted)
      {
        <div class="contact-success">
          <div class="contact-success-icon">&#x2713;</div>
          <h2 class="contact-success-title">Message Sent</h2>
          <p class="contact-success-text">Thanks for reaching out. We'll get back to you faster than a DeLorean hitting 88 mph.</p>
          <a class="btn-secondary" asp-page="/Index" style="margin-top: 20px;">Back to Home</a>
        </div>
      }
      else
      {
        <form method="post" class="contact-form">
          <div class="form-group">
            <label class="form-label" for="name">Name</label>
            <input class="form-input" type="text" id="name" name="Name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input class="form-input" type="email" id="email" name="Email" placeholder="your@@email.com" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea class="form-input form-textarea" id="message" name="Message" placeholder="What's on your mind?" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn-primary" style="width: 100%; text-align: center;">Send Message</button>
        </form>
      }
    </div>
  </div>
</section>
